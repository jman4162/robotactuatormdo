# Local design briefs — kept out of version control by naming convention.
*-GITIGNORE.md

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Lockfile (library — consumers resolve their own deps)
uv.lock

# OS / editor
.DS_Store
.idea/
.vscode/
